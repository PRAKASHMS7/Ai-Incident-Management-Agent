      },
      "id": 1,
      "title": "Total Open Incidents",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(incidents_detected_total) - sum(slack_escalation_delivery_total{status=\"success\"})",
          "legendFormat": "Active Pipeline",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "title": "Slack Escalation Success Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(slack_escalation_delivery_total{status=\"success\"}) / sum(slack_escalation_delivery_total) * 100",
          "legendFormat": "Delivery %",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 3,
      "title": "Incidents Detected by Target Service",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(incidents_detected_total[1h])) by (initial_service)",
          "legendFormat": "{{initial_service}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 4,
      "title": "Operator Acknowledgement Latency",
      "type": "histogram",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(operator_acknowledgement_duration_seconds_bucket[10m])",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    }
  ],
