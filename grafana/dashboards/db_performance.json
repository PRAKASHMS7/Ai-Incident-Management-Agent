      "id": 1,
      "title": "Redis Read Cache Hit Ratio",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(redis_read_cache_hit_total{status=\"hit\"}[5m])) / sum(rate(redis_read_cache_hit_total[5m])) * 100",
          "legendFormat": "Cache Hit %",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Neo4j Active Query Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(neo4j_queries_total[5m]))",
          "legendFormat": "Queries/sec",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 3,
      "title": "Redis Datastore Read/Write Commands Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(redis_commands_total[5m])",
          "legendFormat": "{{command}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
