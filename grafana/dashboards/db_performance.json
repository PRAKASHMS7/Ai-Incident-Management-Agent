        "y": 4
      },
      "id": 4,
      "title": "Neo4j Traversal Latencies",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(neo4j_query_duration_seconds_sum[5m]) / rate(neo4j_query_duration_seconds_count[5m])",
          "legendFormat": "Average Latency",
          "refId": "A"
        }
      ]
